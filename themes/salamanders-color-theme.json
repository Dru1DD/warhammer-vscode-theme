    "parameter": "#A0B098",
    "keyword": "#3E7A48",
    "modifier": "#3E7A48",
    "type": "#7A9070",
    "struct": "#7A9070",
    "decorator": "#7A6028",
    "macro": "#C87828",
    "comment": { "foreground": "#2A3820", "italic": true },
    "string": "#A08A60",
    "number": "#C87828",
    "regexp": "#806840",
