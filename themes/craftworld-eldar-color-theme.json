  "tokenColors": [
    {
      "name": "Comments",
      "scope": ["comment", "punctuation.definition.comment", "string.comment"],
      "settings": { "foreground": "#2A3040", "fontStyle": "italic" }
    },
    {
      "name": "Strings",
      "scope": ["string", "string.quoted", "string.template"],
      "settings": { "foreground": "#709898" }
    },
    {
      "name": "String escape sequences",
      "scope": ["constant.character.escape", "string.regexp", "string.regexp keyword.other"],
      "settings": { "foreground": "#5A8080" }
    },
    {
      "name": "String interpolation",
      "scope": ["punctuation.definition.template-expression", "punctuation.section.embedded"],
      "settings": { "foreground": "#4A7070" }
    },
    {
      "name": "Numbers and boolean literals",
      "scope": [
        "constant.numeric", "constant.language.boolean",
        "constant.language.null", "constant.language.undefined", "constant.language.nan"
      ],
      "settings": { "foreground": "#98B8C0" }
    },
    {
      "name": "Other constants",
      "scope": ["constant.language", "constant.other", "constant.character"],
      "settings": { "foreground": "#98B8C0" }
    },
    {
      "name": "Keywords — control flow",
      "scope": [
        "keyword.control", "keyword.control.flow", "keyword.control.import",
        "keyword.control.from", "keyword.control.export", "keyword.control.default",
        "keyword.control.return", "keyword.control.if", "keyword.control.else",
        "keyword.control.for", "keyword.control.while", "keyword.control.switch",
        "keyword.control.case", "keyword.control.try", "keyword.control.catch",
        "keyword.control.finally", "keyword.control.async", "keyword.control.await"
      ],
      "settings": { "foreground": "#7080A0" }
    },
    {
      "name": "Keywords — operators",
      "scope": [
        "keyword.operator", "keyword.operator.assignment", "keyword.operator.comparison",
        "keyword.operator.logical", "keyword.operator.arithmetic", "keyword.operator.bitwise",
        "keyword.operator.ternary", "keyword.operator.spread", "keyword.operator.optional",
        "keyword.operator.nullcoalescing"
      ],
      "settings": { "foreground": "#5868A0" }
    },
    {
      "name": "Keywords — other",
      "scope": ["keyword", "keyword.other", "keyword.declaration"],
      "settings": { "foreground": "#7080A0" }
    },
    {
      "name": "Storage types",
      "scope": ["storage.type", "storage.modifier"],
      "settings": { "foreground": "#7080A0" }
    },
    {
      "name": "Types and Classes",
      "scope": [
        "entity.name.type", "entity.name.class", "entity.name.namespace",
        "entity.name.scope-resolution", "entity.name.type.class",
        "entity.name.type.interface", "entity.name.type.enum",
        "entity.name.type.alias", "support.class", "support.type"
      ],
      "settings": { "foreground": "#8878A0" }
    },
    {
      "name": "Functions — definition",
      "scope": [
        "entity.name.function",
        "meta.definition.method entity.name.function",
        "meta.function entity.name.function"
      ],
      "settings": { "foreground": "#A0B4CC" }
    },
    {
      "name": "Functions — call",
      "scope": [
        "meta.function-call entity.name.function",
        "meta.function-call.generic entity.name.function",
        "support.function"
      ],
      "settings": { "foreground": "#A0B4CC" }
    },
    {
      "name": "Variables",
      "scope": [
        "variable", "variable.other", "variable.other.readwrite",
        "variable.other.member", "variable.other.property"
      ],
      "settings": { "foreground": "#C8D0DC" }
    },
    {
      "name": "Variables — constants",
      "scope": ["variable.other.constant", "variable.other.enummember"],
      "settings": { "foreground": "#98B8C0" }
    },
    {
      "name": "Variables — parameters",
      "scope": ["variable.parameter", "meta.parameter"],
      "settings": { "foreground": "#A0A8B8" }
    },
    {
      "name": "Properties",
      "scope": [
        "support.type.property-name", "meta.object-literal.key",
        "meta.property-name", "entity.name.tag.yaml", "support.type.property-name.json"
      ],
      "settings": { "foreground": "#A0A8B8" }
    },
    {
      "name": "Enums",
      "scope": ["entity.name.type.enum", "variable.other.enummember"],
      "settings": { "foreground": "#98B8C0" }
    },
    {
      "name": "Interfaces",
      "scope": ["entity.name.type.interface"],
      "settings": { "foreground": "#8878A0", "fontStyle": "italic" }
    },
    {
      "name": "Type parameters / generics",
      "scope": ["meta.type.parameters", "entity.name.type.parameter"],
      "settings": { "foreground": "#8878A0" }
    },
    {
      "name": "HTML/JSX tags",
      "scope": ["entity.name.tag", "meta.tag.sgml", "markup.deleted.git_gutter"],
      "settings": { "foreground": "#6878B0" }
    },
    {
      "name": "HTML/JSX attributes",
      "scope": [
        "entity.other.attribute-name", "entity.other.attribute-name.html",
        "entity.other.attribute-name.jsx"
      ],
      "settings": { "foreground": "#A0B4CC" }
    },
    {
      "name": "CSS — class and id selectors",
      "scope": ["entity.other.attribute-name.class.css", "entity.other.attribute-name.id.css"],
      "settings": { "foreground": "#A0B4CC" }
    },
    {
      "name": "CSS — property names",
      "scope": ["support.type.property-name.css", "meta.property-name.css"],
      "settings": { "foreground": "#A0A8B8" }
    },
    {
      "name": "CSS — units and values",
      "scope": ["constant.numeric.css", "keyword.other.unit.css", "support.constant.property-value.css"],
      "settings": { "foreground": "#98B8C0" }
    },
    {
      "name": "CSS — pseudo-selectors",
      "scope": [
        "entity.other.attribute-name.pseudo-class.css",
        "entity.other.attribute-name.pseudo-element.css"
      ],
      "settings": { "foreground": "#7080A0" }
    },
    {
      "name": "Decorators / annotations",
      "scope": [
        "meta.decorator", "meta.decorator punctuation.decorator",
        "entity.name.function.decorator", "punctuation.definition.decorator"
      ],
      "settings": { "foreground": "#6858A0" }
    },
    {
      "name": "Punctuation — general",
      "scope": [
        "punctuation", "punctuation.separator", "punctuation.terminator",
        "punctuation.accessor", "meta.brace", "punctuation.definition.binding-pattern"
      ],
      "settings": { "foreground": "#485868" }
    },
    {
      "name": "Punctuation — brackets",
      "scope": ["punctuation.definition.tag", "punctuation.definition.tag.begin", "punctuation.definition.tag.end"],
      "settings": { "foreground": "#384858" }
    },
    {
      "name": "Support constants",
      "scope": ["support.constant", "support.variable"],
      "settings": { "foreground": "#8878A0" }
    },
    {
      "name": "Support types — primitives",
      "scope": ["support.type.primitive", "support.type.builtin"],
      "settings": { "foreground": "#7080A0" }
    },
    {
      "name": "Errors and invalids",
      "scope": ["invalid", "invalid.illegal"],
      "settings": { "foreground": "#C02A2A", "fontStyle": "underline" }
    },
    {
      "name": "Deprecated",
      "scope": ["invalid.deprecated"],
      "settings": { "foreground": "#785090", "fontStyle": "underline" }
    },
    {
      "name": "Markdown — headings",
      "scope": ["markup.heading", "markup.heading entity.name", "punctuation.definition.heading.markdown"],
      "settings": { "foreground": "#A0B4CC", "fontStyle": "bold" }
    },
    {
      "name": "Markdown — bold",
      "scope": ["markup.bold", "markup.bold string"],
      "settings": { "fontStyle": "bold" }
    },
    {
      "name": "Markdown — italic",
      "scope": ["markup.italic", "markup.italic string"],
      "settings": { "fontStyle": "italic" }
    },
    {
      "name": "Markdown — inline code",
      "scope": ["markup.inline.raw", "markup.raw"],
      "settings": { "foreground": "#8898A8" }
    },
    {
      "name": "Markdown — fenced code block",
      "scope": ["markup.fenced_code.block", "markup.fenced_code.block punctuation"],
      "settings": { "foreground": "#8898A8" }
    },
    {
      "name": "Markdown — blockquote",
      "scope": ["markup.quote", "punctuation.definition.blockquote"],
      "settings": { "foreground": "#8898A8", "fontStyle": "italic" }
    },
    {
      "name": "Markdown — links",
      "scope": ["markup.underline.link", "string.other.link"],
      "settings": { "foreground": "#7090B0" }
    },
    {
      "name": "Markdown — list bullets",
      "scope": [
        "punctuation.definition.list.begin.markdown",
        "markup.list punctuation.definition.list.begin"
      ],
      "settings": { "foreground": "#6878B0" }
    },
    {
      "name": "Markdown — diff inserted",
      "scope": "markup.inserted",
      "settings": { "foreground": "#2A6848" }
    },
    {
      "name": "Markdown — diff deleted",
      "scope": "markup.deleted",
      "settings": { "foreground": "#784858" }
    },
    {
      "name": "Markdown — diff changed",
      "scope": "markup.changed",
      "settings": { "foreground": "#6878A8" }
    }
  ],
  "semanticHighlighting": true,
  "semanticTokenColors": {
    "namespace": "#8878A0",
    "class": "#8878A0",
    "interface": { "foreground": "#8878A0", "italic": true },
    "enum": "#98B8C0",
    "enumMember": "#98B8C0",
    "typeParameter": "#8878A0",
    "function": "#A0B4CC",
    "method": "#A0B4CC",
    "property": "#A0A8B8",
    "property.readonly": "#98B8C0",
    "variable": "#C8D0DC",
    "variable.readonly": "#98B8C0",
    "parameter": "#A0A8B8",
    "keyword": "#7080A0",
    "modifier": "#7080A0",
    "type": "#8878A0",
    "struct": "#8878A0",
    "decorator": "#6858A0",
    "macro": "#98B8C0",
    "comment": { "foreground": "#2A3040", "italic": true },
    "string": "#709898",
    "number": "#98B8C0",
    "regexp": "#5A8080",
    "operator": "#5868A0",
    "selfParameter": { "foreground": "#7080A0", "italic": true },
    "clsParameter": { "foreground": "#7080A0", "italic": true }
  }
}
