  "tokenColors": [
    {
      "name": "Comments",
      "scope": [
        "comment",
        "punctuation.definition.comment",
        "string.comment"
      ],
      "settings": {
        "foreground": "#6A6A7E",
        "fontStyle": "italic"
      }
    },
    {
      "name": "Strings",
      "scope": [
        "string",
        "string.quoted",
        "string.template"
      ],
      "settings": {
        "foreground": "#9A8B72"
      }
    },
    {
      "name": "String escape sequences",
      "scope": [
        "constant.character.escape",
        "string.regexp",
        "string.regexp keyword.other"
      ],
      "settings": {
        "foreground": "#806838"
      }
    },
    {
      "name": "String interpolation",
      "scope": [
        "punctuation.definition.template-expression",
        "punctuation.section.embedded"
      ],
      "settings": {
        "foreground": "#686038"
      }
    },
    {
      "name": "Numbers and boolean literals",
      "scope": [
        "constant.numeric",
        "constant.language.boolean",
        "constant.language.null",
        "constant.language.undefined",
        "constant.language.nan"
      ],
      "settings": {
        "foreground": "#7A6045"
      }
    },
    {
      "name": "Other constants",
      "scope": [
        "constant.language",
        "constant.other",
        "constant.character"
      ],
      "settings": {
        "foreground": "#7A6045"
      }
    },
    {
      "name": "Keywords — control flow",
      "scope": [
        "keyword.control",
        "keyword.control.flow",
        "keyword.control.import",
        "keyword.control.from",
        "keyword.control.export",
        "keyword.control.default",
        "keyword.control.return",
        "keyword.control.if",
        "keyword.control.else",
        "keyword.control.for",
        "keyword.control.while",
        "keyword.control.switch",
        "keyword.control.case",
        "keyword.control.try",
        "keyword.control.catch",
        "keyword.control.finally",
        "keyword.control.async",
        "keyword.control.await"
      ],
      "settings": {
        "foreground": "#4A6888"
      }
    },
    {
      "name": "Keywords — operators",
      "scope": [
        "keyword.operator",
        "keyword.operator.assignment",
        "keyword.operator.comparison",
        "keyword.operator.logical",
        "keyword.operator.arithmetic",
        "keyword.operator.bitwise",
        "keyword.operator.ternary",
        "keyword.operator.spread",
        "keyword.operator.optional",
        "keyword.operator.nullcoalescing"
      ],
      "settings": {
        "foreground": "#3A5878"
      }
    },
    {
      "name": "Keywords — other",
      "scope": [
        "keyword",
        "keyword.other",
        "keyword.declaration"
      ],
      "settings": {
        "foreground": "#4A6888"
      }
    },
    {
      "name": "Storage types",
      "scope": [
        "storage.type",
        "storage.modifier"
      ],
      "settings": {
        "foreground": "#4A6888"
      }
    },
    {
      "name": "Types and Classes",
      "scope": [
        "entity.name.type",
        "entity.name.class",
        "entity.name.namespace",
        "entity.name.scope-resolution",
        "entity.name.type.class",
        "entity.name.type.interface",
        "entity.name.type.enum",
        "entity.name.type.alias",
        "support.class",
        "support.type"
      ],
      "settings": {
        "foreground": "#787888"
      }
    },
    {
      "name": "Functions — definition",
      "scope": [
        "entity.name.function",
        "meta.definition.method entity.name.function",
        "meta.function entity.name.function"
      ],
      "settings": {
        "foreground": "#8A8A5A"
      }
    },
    {
      "name": "Functions — call",
      "scope": [
        "meta.function-call entity.name.function",
        "meta.function-call.generic entity.name.function",
        "support.function"
      ],
      "settings": {
        "foreground": "#8A8A5A"
      }
    },
    {
      "name": "Variables",
      "scope": [
        "variable",
        "variable.other",
        "variable.other.readwrite",
        "variable.other.member",
