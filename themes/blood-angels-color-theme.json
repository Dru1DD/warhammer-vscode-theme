  "tokenColors": [
    {
      "name": "Comments",
      "scope": [
        "comment",
        "punctuation.definition.comment",
        "string.comment"
      ],
      "settings": {
        "foreground": "#4A4852",
        "fontStyle": "italic"
      }
    },
    {
      "name": "Strings",
      "scope": [
        "string",
        "string.quoted",
        "string.template"
      ],
      "settings": {
        "foreground": "#B8955A"
      }
    },
    {
      "name": "String escape sequences",
      "scope": [
        "constant.character.escape",
        "string.regexp",
        "string.regexp keyword.other"
      ],
      "settings": {
        "foreground": "#A07840"
      }
    },
    {
      "name": "String interpolation",
      "scope": [
        "punctuation.definition.template-expression",
        "punctuation.section.embedded"
      ],
      "settings": {
        "foreground": "#8B7838"
      }
    },
    {
      "name": "Numbers and boolean literals",
      "scope": [
        "constant.numeric",
        "constant.language.boolean",
        "constant.language.null",
        "constant.language.undefined",
        "constant.language.nan"
      ],
      "settings": {
        "foreground": "#A87850"
      }
    },
    {
      "name": "Other constants",
      "scope": [
        "constant.language",
        "constant.other",
        "constant.character"
      ],
      "settings": {
        "foreground": "#A87850"
      }
    },
    {
      "name": "Keywords — control flow",
      "scope": [
        "keyword.control",
        "keyword.control.flow",
        "keyword.control.import",
        "keyword.control.from",
        "keyword.control.export",
        "keyword.control.default",
        "keyword.control.return",
        "keyword.control.if",
        "keyword.control.else",
        "keyword.control.for",
        "keyword.control.while",
        "keyword.control.switch",
        "keyword.control.case",
        "keyword.control.try",
        "keyword.control.catch",
        "keyword.control.finally",
        "keyword.control.async",
        "keyword.control.await"
      ],
      "settings": {
        "foreground": "#6A88A0"
      }
    },
    {
      "name": "Keywords — operators",
      "scope": [
        "keyword.operator",
        "keyword.operator.assignment",
        "keyword.operator.comparison",
        "keyword.operator.logical",
        "keyword.operator.arithmetic",
        "keyword.operator.bitwise",
        "keyword.operator.ternary",
        "keyword.operator.spread",
        "keyword.operator.optional",
        "keyword.operator.nullcoalescing"
      ],
      "settings": {
        "foreground": "#5A7888"
      }
    },
    {
      "name": "Keywords — other",
      "scope": [
        "keyword",
        "keyword.other",
        "keyword.declaration"
      ],
      "settings": {
        "foreground": "#6A88A0"
      }
    },
    {
      "name": "Storage types — var, let, const, function, class",
      "scope": [
        "storage.type",
        "storage.modifier"
      ],
      "settings": {
        "foreground": "#6A88A0"
      }
    },
    {
      "name": "Types and Classes",
      "scope": [
        "entity.name.type",
        "entity.name.class",
        "entity.name.namespace",
        "entity.name.scope-resolution",
        "entity.name.type.class",
        "entity.name.type.interface",
        "entity.name.type.enum",
        "entity.name.type.alias",
        "support.class",
        "support.type"
      ],
      "settings": {
        "foreground": "#A090B0"
      }
    },
    {
      "name": "Functions — definition",
      "scope": [
        "entity.name.function",
        "meta.definition.method entity.name.function",
        "meta.function entity.name.function"
      ],
      "settings": {
