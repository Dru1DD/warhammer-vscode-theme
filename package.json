{
  "name": "warhammer-40k-theme",
  "displayName": "Warhammer 40k: Grimdark Elite",
  "description": "Premium faction themes for Warhammer 40k devotees. Sixteen carefully crafted dark, mid-dark, and light environments for long coding sessions.",
  "version": "0.5.0",
  "publisher": "Dru1DD",
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": [
    "Themes",
    "Other"
  ],
  "keywords": [
    "theme",
    "dark",
    "warhammer",
    "grimdark",
    "blood angels",
    "deathwatch",
    "salamanders",
    "imperial fists",
    "eldar",
    "tau",
    "premium",
    "elegant",
    "light theme",
    "white scars",
    "thousand sons",
    "sisters of battle",
    "raven guard",
    "alpha legion",
    "custodes"
  ],
  "galleryBanner": {
    "color": "#0D0D0F",
    "theme": "dark"
  },
  "icon": "images/icon.png",
  "repository": {
    "type": "git",
    "url": "https://github.com/Dru1DD/warhammer-vscode-theme"
  },
  "license": "MIT",
  "main": "./out/extension.js",
  "activationEvents": [],
  "contributes": {
    "views": {
      "explorer": [
        {
          "type": "webview",
          "id": "warhammer.mascotView",
          "name": "Servo-Skull"
        }
      ]
    },
    "themes": [
      {
        "label": "Blood Angels",
        "uiTheme": "vs-dark",
        "path": "./themes/blood-angels-color-theme.json"
      },
      {
        "label": "Deathwatch",
        "uiTheme": "vs-dark",
        "path": "./themes/deathwatch-color-theme.json"
      },
      {
        "label": "Necrons",
        "uiTheme": "vs-dark",
        "path": "./themes/necrons-color-theme.json"
      },
      {
        "label": "Ultramarines",
        "uiTheme": "vs-dark",
        "path": "./themes/ultramarines-color-theme.json"
      },
      {
        "label": "Adeptus Mechanicus",
        "uiTheme": "vs-dark",
        "path": "./themes/adeptus-mechanicus-color-theme.json"
      },
      {
        "label": "Death Guard",
        "uiTheme": "vs-dark",
        "path": "./themes/death-guard-color-theme.json"
      },
      {
        "label": "Salamanders",
        "uiTheme": "vs-dark",
        "path": "./themes/salamanders-color-theme.json"
      },
      {
        "label": "Imperial Fists",
        "uiTheme": "vs-dark",
        "path": "./themes/imperial-fists-color-theme.json"
      },
      {
        "label": "Craftworld Eldar",
        "uiTheme": "vs-dark",
        "path": "./themes/craftworld-eldar-color-theme.json"
      },
      {
        "label": "Tau Empire",
        "uiTheme": "vs-dark",
        "path": "./themes/tau-empire-color-theme.json"
      },
      {
        "label": "White Scars",
        "uiTheme": "vs",
        "path": "./themes/white-scars-color-theme.json"
      },
      {
        "label": "Thousand Sons",
        "uiTheme": "vs",
        "path": "./themes/thousand-sons-color-theme.json"
      },
      {
        "label": "Sisters of Battle",
        "uiTheme": "vs",
        "path": "./themes/sisters-of-battle-color-theme.json"
      },
      {
        "label": "Raven Guard",
        "uiTheme": "vs",
        "path": "./themes/raven-guard-color-theme.json"
      },
      {
        "label": "Alpha Legion",
        "uiTheme": "vs",
        "path": "./themes/alpha-legion-color-theme.json"
      },
      {
        "label": "Custodes",
        "uiTheme": "vs",
        "path": "./themes/custodes-color-theme.json"
      }
    ],
    "commands": [
      {
        "command": "warhammer.toggleCompanion",
        "title": "Warhammer 40k: Toggle Servo-Skull Companion",
        "category": "Warhammer 40k"
      },
      {
        "command": "warhammer.companionSpeak",
        "title": "Warhammer 40k: Consult the Servo-Skull",
        "category": "Warhammer 40k"
      },
      {
        "command": "warhammer.summonMascot",
        "title": "Warhammer 40k: Summon the Servo-Skull",
        "category": "Warhammer 40k"
      }
    ],
    "configuration": {
      "title": "Warhammer 40k Theme",
      "properties": {
        "warhammer.companion.enabled": {
          "type": "boolean",
          "default": true,
          "description": "Enable the Servo-Skull companion in the status bar."
        },
        "warhammer.companion.notificationsEnabled": {
          "type": "boolean",
          "default": true,
          "description": "Allow the Servo-Skull to occasionally deliver transmissions."
        },
        "warhammer.companion.saveReactions": {
          "type": "boolean",
          "default": true,
          "description": "Allow the Servo-Skull to react when you save files (10% chance)."
        },
        "warhammer.mascot.enabled": {
          "type": "boolean",
          "default": true,
          "description": "Enable the floating Servo-Skull mascot companion."
        },
        "warhammer.mascot.faction": {
          "type": "string",
          "default": "auto",
          "enum": [
            "auto",
            "bloodAngels",
            "deathwatch",
            "necrons",
            "ultramarines",
            "mechanicus",
            "deathGuard",
            "salamanders",
            "imperialFists",
            "craftEldar",
            "tau",
            "whiteScars",
            "thousandSons",
            "sistersBattle",
            "ravenGuard",
            "alphaLegion",
            "custodes"
          ],
          "enumDescriptions": [
            "Detect faction from the active color theme.",
            "Blood Angels — noble, crimson authority. Duty and sacrifice.",
            "Deathwatch — tactical, dark military precision. Stoic vigilance.",
            "Necrons — ancient, detached machine consciousness. Dry cosmic contempt.",
            "Ultramarines — confident, codex-adherent authority. By-the-book excellence.",
            "Adeptus Mechanicus — reverent, ritualistic. Sacred machine communion.",
            "Death Guard — weary, plague-touched endurance. Grinding persistence.",
            "Salamanders — grounded, protective warmth. Forge-craft and kinship.",
            "Imperial Fists — stoic, fortification-minded resolve. Unyielding walls.",
            "Craftworld Eldar — elegant, melancholy foresight. Ancient and sorrowful.",
            "Tau Empire — optimistic, utilitarian efficiency. The Greater Good.",
            "White Scars — swift, fierce independence. Speed and open sky.",
            "Thousand Sons — arcane, scholarly melancholy. Cursed knowledge.",
            "Sisters of Battle — fierce devotional fire. Faith as weapon and shield.",
            "Raven Guard — quiet, shadowed patience. Strike from silence.",
            "Alpha Legion — layered, cryptic misdirection. Every plan has a plan.",
            "Adeptus Custodes — measured imperial gravitas. Gold-clad certainty."
          ],
          "description": "Faction voice for the mascot companion. 'auto' inherits from the active theme."
        },
        "warhammer.mascot.displayDuration": {
          "type": "number",
          "default": 8,
          "minimum": 3,
          "maximum": 30,
          "description": "How long (seconds) the Servo-Skull remains visible before fading out."
        },
        "warhammer.mascot.ambientFrequency": {
          "type": "string",
          "default": "rare",
          "enum": ["off", "rare", "occasional"],
          "enumDescriptions": [
            "No ambient appearances.",
            "Appears roughly once every 90–130 minutes.",
            "Appears roughly once every 45–75 minutes."
          ],
          "description": "How often the Servo-Skull makes unprompted ambient appearances."
        },
        "warhammer.mascot.longSessionThreshold": {
          "type": "number",
          "default": 2,
          "minimum": 1,
          "maximum": 8,
          "description": "Hours of continuous editing before the long-session message is shown (once per session)."
        }
      }
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "package": "vsce package"
  },
  "devDependencies": {
    "@types/vscode": "^1.85.0",
    "@types/node": "^20.0.0",
    "typescript": "^5.3.0",
    "@vscode/vsce": "^2.22.0"
  }
}
